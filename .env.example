# ── LLM ──────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Search ────────────────────────────────────────────
TAVILY_API_KEY=your_tavily_api_key_here

# ── Models ────────────────────────────────────────────
FAST_MODEL=claude-haiku-4-5-20251001        # planning, extraction, summarization
REPORT_MODEL=claude-sonnet-4-20250514        # report writing, verification

# ── Server ────────────────────────────────────────────
PORT=8000
CORS_ORIGINS=http://localhost:3000,https://yourusername.github.io

# ── Database ──────────────────────────────────────────
DATABASE_PATH=./data/sessions.db

# ── Limits ────────────────────────────────────────────
MAX_CONCURRENT_SESSIONS=3
MAX_VERIFICATION_ATTEMPTS=2
MAX_SEARCH_RESULTS_PER_TOPIC=5

# ── Modes ─────────────────────────────────────────────
DEFAULT_MODE=deep        # deep | quick
